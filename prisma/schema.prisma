generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum AppModule {
  TASKS
  USERS
  AUDIT
  ANALYTICS
  SETTINGS
}

enum PermissionAction {
  READ
  WRITE
  DELETE
  MANAGE
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_STATUS_CHANGED
  TASK_COMMENT_ADDED
  TASK_DUE_SOON
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users         User[]
  tasks         Task[]
  notifications Notification[]
}

model User {
  id         String    @id @default(cuid())
  name       String
  email      String    @unique
  password   String
  role       Role      @default(EMPLOYEE)
  tenantId   String
  isBanned   Boolean   @default(false)
  bannedAt   DateTime?
  bannedById String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  bannedBy        User?            @relation("BannedByUser", fields: [bannedById], references: [id])
  bannedUsers     User[]           @relation("BannedByUser")
  auditLogs       AuditLog[]
  assignedTasks   Task[]           @relation("AssignedTasks")
  createdTasks    Task[]           @relation("CreatedTasks")
  assignedByTasks Task[]           @relation("AssignedByTasks")
  permissions     UserPermission[]
  taskHistory     TaskHistory[]    @relation("TaskHistoryUser")
  taskComments    TaskComment[]    @relation("TaskCommentUser")
  notifications   Notification[]

  @@index([tenantId])
  @@index([email])
}

model UserPermission {
  id        String           @id @default(cuid())
  userId    String
  module    AppModule
  action    PermissionAction
  // true = explicitly granted, false = explicitly denied (overrides role default)
  granted   Boolean
  tenantId  String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, module, action])
  @@index([userId])
  @@index([tenantId])
}

model Task {
  id           String     @id @default(cuid())
  title        String
  description  String?
  status       TaskStatus @default(TODO)
  priority     Int        @default(2) // 1=low, 2=medium, 3=high
  tenantId     String
  assignedToId String?
  assignedById String?
  createdById  String
  dueDate      DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant     Tenant        @relation(fields: [tenantId], references: [id])
  assignedTo User?         @relation("AssignedTasks", fields: [assignedToId], references: [id])
  assignedBy User?         @relation("AssignedByTasks", fields: [assignedById], references: [id])
  createdBy  User          @relation("CreatedTasks", fields: [createdById], references: [id])
  history    TaskHistory[]
  comments   TaskComment[]
  labels     TaskLabel[]
  subtasks   Subtask[]

  @@index([tenantId])
  @@index([assignedToId])
  @@index([createdById])
  @@index([status])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model Label {
  id       String      @id @default(cuid())
  name     String
  color    String      @default("#6366f1")
  tenantId String
  tasks    TaskLabel[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model TaskLabel {
  taskId  String
  labelId String

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
}

model Subtask {
  id          String   @id @default(cuid())
  taskId      String
  title       String
  completed   Boolean  @default(false)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskHistory {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  // Array of { field, oldValue, newValue } stored as JSON
  changes   Json
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("TaskHistoryUser", fields: [userId], references: [id])

  @@index([taskId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation("TaskCommentUser", fields: [userId], references: [id])

  @@index([taskId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  tenantId  String
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  taskId    String?
  createdAt DateTime         @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([userId, read])
  @@index([tenantId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  userId    String
  tenantId  String
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
  @@index([tenantId, createdAt])
}
