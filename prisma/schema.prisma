generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users User[]
  tasks Task[]
}

model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String
  role     Role   @default(EMPLOYEE)
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
}

model Task {
  id       String @id @default(cuid())
  title    String
  status   String
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  assignedTo String?
  createdAt  DateTime @default(now())
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}
